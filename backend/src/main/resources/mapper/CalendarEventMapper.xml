<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.kaity.travel.backend.domain.todo.mapper.CalendarEventMapper">

    <select id="getAllEvents" resultType="com.kaity.travel.backend.domain.todo.entity.CalendarEvent">
        SELECT * 
        FROM calendar_event
        ORDER BY start_time ASC
    </select>

    <select id="getEventById" parameterType="long" resultType="com.kaity.travel.backend.domain.todo.entity.CalendarEvent">
        SELECT * 
        FROM calendar_event
        WHERE id = #{id}
    </select>

    <insert id="createEvent" parameterType="com.kaity.travel.backend.domain.todo.entity.CalendarEvent" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO calendar_event (
             title
            ,description
            ,start_time
            ,end_time
            ,location
            ,travel_related
            ,trip_id
            ,created_at
        )
        VALUES (
             #{title}
            ,#{description}
            ,#{startTime}
            ,#{endTime}
            ,#{location}
            ,#{travelRelated}
            ,#{tripId}
            ,#{createdAt}
        )
    </insert>

    <update id="updateEvent" parameterType="com.kaity.travel.backend.domain.todo.entity.CalendarEvent">
        UPDATE calendar_event 
        SET    title          =    #{title}
              ,description    =    #{description}
              ,start_time     =    #{startTime}
              ,end_time       =    #{endTime}
              ,location       =    #{location}
              ,travel_related =    #{travelRelated}
              ,trip_id        =    #{tripId}
        WHERE id = #{id}
    </update>

    <delete id="deleteEvent" parameterType="long">
        DELETE FROM calendar_event WHERE id = #{id}
    </delete>

</mapper>
